# Keep the image lean and never bake in local state or secrets.
.git/
.github/
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
build/
dist/

# Local runtime state (regenerated in the container)
cache/
knowledge/
reports/
keys/
*.sqlite
*.key
ariadne.config.json

# Large generated feeds — run `ariadne update-intel` in the container instead
ariadne/data/intel_labels.json
ariadne/data/ofac_sanctioned.json

# Editor / preview
.claude/
